<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="orders.OrderController"
      stylesheets="@../application/application.css"
      style="-fx-background-color: #0B0F19; -fx-padding: 20;">

    <!-- TITLE -->
    <Label text="ORDERING SYSTEM" styleClass="title"/>

    <!-- INPUT SECTION -->
    <VBox spacing="10" style="-fx-background-color: #161D30; -fx-padding: 15; -fx-background-radius: 10;">

        <ComboBox fx:id="foodComboBox" promptText="Select Food"/>
        <TextField fx:id="quantityField" promptText="Enter Quantity"/>

        <Button text="Add to Cart" onAction="#handleAddToCart" styleClass="button-green"/>

    </VBox>

    <!-- TABLE SECTION -->
    <VBox spacing="10" style="-fx-background-color: #161D30; -fx-padding: 15; -fx-background-radius: 10;">

        <TableView fx:id="tableView" prefHeight="200">
            <columns>
                <TableColumn fx:id="nameColumn" text="Food"/>
                <TableColumn fx:id="quantityColumn" text="Qty"/>
                <TableColumn fx:id="priceColumn" text="Price"/>
                <TableColumn fx:id="subtotalColumn" text="Subtotal"/>
            </columns>
        </TableView>

        <Button text="Remove Item" onAction="#handleRemoveItem" styleClass="button-danger"/>

    </VBox>

    <!-- TOTAL + CONFIRM -->
    <VBox spacing="10" alignment="CENTER">

        <Label fx:id="totalLabel" text="Total: GHS 0" styleClass="title"/>

        <Button text="Confirm Order" onAction="#handleConfirmOrder" styleClass="button-green"/>

    </VBox>

</VBox>